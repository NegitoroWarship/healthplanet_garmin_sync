# HealthPlanet OAuth credentials (https://www.healthplanet.jp/apis/registinfo.do)
HEALTHPLANET_CLIENT_ID=your_client_id
HEALTHPLANET_CLIENT_SECRET=your_client_secret
# Must match the redirect URI registered for your app.
# For non-web apps the success page works (shows the auth code in the page):
HEALTHPLANET_REDIRECT_URI=https://www.healthplanet.jp/success.html

# Garmin Connect credentials (MFA disabled assumed)
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your_password

# Where tokens + sync state are persisted (mounted PVC in k8s)
DATA_DIR=./data

# Initial look-back window (days) used only when no state exists yet.
LOOKBACK_DAYS=90

# Optional hard floor: only measurements AFTER this are ever considered.
# Use this if some weights are already in Garmin (e.g. entered manually) and you
# only want to sync newer ones. Accepts YYYYMMDD or YYYYMMDDHHMM. Leave empty to
# disable. Alternatively run `python -m src.sync --seed` once (see README).
# SYNC_SINCE=20260614

# Timezone of HealthPlanet measurements (do not change).
HEALTHPLANET_TZ_OFFSET_HOURS=9
